{
  "name": "mk-online",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "test": "npm run test --workspace shared",
    "build": "npm run build --workspace shared",
    "serve": "npm run build --workspace client && npm run start --workspace server"
  },
  "engines": {
    "node": ">=20"
  },
  "allowScripts": {
    "esbuild@0.21.5": true,
    "esbuild@0.28.1": true
  }
}
